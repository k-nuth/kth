#include <kth/domain/version.hpp>

namespace kth {

// Only this translation unit sees the build-time version string. Bumping
// `KTH_VERSION` (e.g. across a commit-count change in the CI build) only
// forces `version.cpp.o` to be rebuilt, not every TU that includes the
// header.
std::string_view const version = "@KTH_VERSION@";

} // namespace kth
