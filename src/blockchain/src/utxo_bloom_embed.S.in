// Embeds the UTXO bloom filter binary data into the executable's read-only data section.
// The .incbin directive includes the file at assembly time — no hex conversion needed,
// fast compilation, and zero runtime cost. Data is accessed via extern "C" symbols.

#if defined(__APPLE__)
    .section __TEXT,__const
#else
    .section .rodata,"a",@progbits
#endif

#if defined(__APPLE__)
    .globl _kth_utxo_bloom_data
    .globl _kth_utxo_bloom_data_end
    .p2align 3
_kth_utxo_bloom_data:
    .incbin "@UTXO_BLOOM_DAT_PATH@"
_kth_utxo_bloom_data_end:
#else
    .globl kth_utxo_bloom_data
    .globl kth_utxo_bloom_data_end
    .balign 8
kth_utxo_bloom_data:
    .incbin "@UTXO_BLOOM_DAT_PATH@"
kth_utxo_bloom_data_end:
#endif
